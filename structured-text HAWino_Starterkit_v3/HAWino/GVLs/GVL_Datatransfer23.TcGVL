{attribute 'qualified_only'}

TYPE sFahrvektor :
	STRUCT
		reWinkel : REAL;           // Fahrtrichtung
		inGeschwindigkeit : INT;   // Fahrgeschwindigkeit
	END_STRUCT
END_TYPE

TYPE sPositions :
	STRUCT
		inX : INT;       // X-Position
		inY : INT;       // Y-Position
		inWinkel : REAL; // Ausrichtung
	END_STRUCT
END_TYPE

VAR_GLOBAL
	// Definition der Steuerungsvariable
	inControl : INT;           // 0=idle, 1=Stop, 2=Reset, 3=Vektor, 4=Position
END_VAR