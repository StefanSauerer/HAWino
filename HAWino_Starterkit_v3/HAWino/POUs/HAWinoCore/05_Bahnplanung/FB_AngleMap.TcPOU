<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="FB_AngleMap" Id="{c31446c6-620f-4482-b5b3-9d926dd4eb88}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_AngleMap
VAR_INPUT
    xinGoalID  : INT;    (* 1..13 — welche Karte dieser Baustein lädt *)
    xboLoad    : BOOL;   (* steigende Flanke startet Ladevorgang      *)
END_VAR
VAR_OUTPUT
    yboDone    : BOOL;
    yboError   : BOOL;
    yinProgress: INT;
END_VAR
VAR
    (* Eigenes Array — nur in dieser Instanz, nicht global *)
    _sarMap      : ARRAY[0..399, 0..799] OF INT;

    _inState     : INT := 0;
    _stiPath     : STRING(255);
    _udExpected  : UDINT := 400 * 800 * 2;
    _fbFileOpen  : FB_FileOpen;
    _fbFileRead  : FB_FileRead;
    _fbFileClose : FB_FileClose;
    _rTrigLoad   : R_TRIG;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[
(* Flanke auf xboLoad erkennen *)
_rTrigLoad(CLK := xboLoad);

IF _rTrigLoad.Q AND NOT yboDone THEN
    _inState := 0;
    yboDone  := FALSE;
    yboError := FALSE;
END_IF

IF yboDone OR yboError THEN RETURN; END_IF

CASE _inState OF

    0:  (* Pfad aufbauen *)
        IF xinGoalID < 10 THEN
            _stiPath := CONCAT(GVL_Maps.stiMapPath,
                          CONCAT('angle_map_0',
                            CONCAT(TO_STRING(xinGoalID), '.bin')));
        ELSE
            _stiPath := CONCAT(GVL_Maps.stiMapPath,
                          CONCAT('angle_map_',
                            CONCAT(TO_STRING(xinGoalID), '.bin')));
        END_IF

        _fbFileOpen(
            sNetId    := '',
            sPathName := _stiPath,
            nMode     := FOPEN_MODEREAD OR FOPEN_MODEBINARY,
            bExecute  := TRUE);

        _inState := 1;

    1:  (* Warten bis Datei offen *)
        _fbFileOpen(bExecute := FALSE);

        IF _fbFileOpen.bBusy THEN RETURN; END_IF

        IF _fbFileOpen.bError THEN
            yboError := TRUE;
            RETURN;
        END_IF

        _fbFileRead(
            sNetId     := '',
            hFile      := _fbFileOpen.hFile,
            pReadBuff  := ADR(_sarMap[0, 0]),
            cbReadLen  := _udExpected,
            bExecute   := TRUE);

        _inState := 2;

    2:  (* Warten bis Lesen fertig *)
        _fbFileRead(bExecute := FALSE);

        IF _fbFileRead.bBusy THEN RETURN; END_IF

        IF _fbFileRead.bError OR _fbFileRead.cbRead <> _udExpected THEN
            yboError := TRUE;
            RETURN;
        END_IF

        _fbFileClose(
            sNetId   := '',
            hFile    := _fbFileOpen.hFile,
            bExecute := TRUE);

        _inState := 3;

    3:  (* Warten bis Datei geschlossen *)
        _fbFileClose(bExecute := FALSE);

        IF _fbFileClose.bBusy THEN RETURN; END_IF

        yinProgress := 100;
        yboDone     := TRUE;
        _inState    := 4;

    4:  (* Fertig — nichts mehr tun *)
        ;

END_CASE

(* Fortschritt während Laden *)
IF _inState > 0 AND _inState < 4 THEN
    yinProgress := _inState * 25;
END_IF]]></ST>
    </Implementation>
    <Method Name="GETAngle" Id="{92fa7de6-9d84-442a-b9e6-cb63a622dec8}">
      <Declaration><![CDATA[METHOD GETAngle : INT
VAR_INPUT
    xinPosX : INT;
    xinPosY : INT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[GetAngle := _sarMap[
    MAX(0, MIN(xinPosY, 399)),
    MAX(0, MIN(xinPosX, 799))];]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetAngleInterp" Id="{6261e78d-fd7c-4697-b00f-852b85dab3b9}">
      <Declaration><![CDATA[METHOD GetAngleInterp : REAL
VAR_INPUT
    xrePosX : REAL;
    xrePosY : REAL;
END_VAR
VAR
    _inX0, _inX1 : INT;
    _inY0, _inY1 : INT;
    _reFx, _reFy : REAL;

    _reA00, _reA10 : REAL;
    _reA01, _reA11 : REAL;

    _reSin00, _reSin10 : REAL;
    _reSin01, _reSin11 : REAL;
    _reCos00, _reCos10 : REAL;
    _reCos01, _reCos11 : REAL;

    _reSinInterp : REAL;
    _reCosInterp : REAL;
    _crePI       : REAL := 3.14159265358979;

    (* Hilfsvariablen für korrektes Abschneiden *)
    _reFloorX    : REAL;
    _reFloorY    : REAL;
    _inRaw00     : INT;
    _inRaw10     : INT;
    _inRaw01     : INT;
    _inRaw11     : INT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* FLOOR: abschneiden statt runden *)
(* REAL_TO_INT rundet — deshalb manuell mit TRUNC *)
_reFloorX := TRUNC(xrePosX);
_reFloorY := TRUNC(xrePosY);

(* Gebrochene Anteile — immer 0.0 bis <1.0 *)
_reFx := xrePosX - _reFloorX;
_reFy := xrePosY - _reFloorY;

(* Pixelkoordinaten der 4 Eckpunkte *)
_inX0 := MAX(0, MIN(REAL_TO_INT(_reFloorX),     798));
_inX1 := MAX(0, MIN(REAL_TO_INT(_reFloorX) + 1, 799));
_inY0 := MAX(0, MIN(REAL_TO_INT(_reFloorY),     398));
_inY1 := MAX(0, MIN(REAL_TO_INT(_reFloorY) + 1, 399));

(* Rohe INT-Werte aus dem Array *)
_inRaw00 := _sarMap[_inY0, _inX0];
_inRaw10 := _sarMap[_inY0, _inX1];
_inRaw01 := _sarMap[_inY1, _inX0];
_inRaw11 := _sarMap[_inY1, _inX1];

(* Sonderwerte: wenn ein Nachbar Hindernis oder Ziel ist
   → nur den gültigen Pixel verwenden                    *)
IF _inRaw00 = -9999 OR _inRaw00 = -8888 THEN
    _inRaw00 := _inRaw11;
END_IF
IF _inRaw10 = -9999 OR _inRaw10 = -8888 THEN
    _inRaw10 := _inRaw00;
END_IF
IF _inRaw01 = -9999 OR _inRaw01 = -8888 THEN
    _inRaw01 := _inRaw00;
END_IF
IF _inRaw11 = -9999 OR _inRaw11 = -8888 THEN
    _inRaw11 := _inRaw00;
END_IF

(* Winkel in Grad (÷10 wegen Skalierung) *)
_reA00 := INT_TO_REAL(_inRaw00) / 10.0;
_reA10 := INT_TO_REAL(_inRaw10) / 10.0;
_reA01 := INT_TO_REAL(_inRaw01) / 10.0;
_reA11 := INT_TO_REAL(_inRaw11) / 10.0;

(* Sin/Cos der 4 Winkel *)
_reSin00 := SIN(_reA00 * _crePI / 180.0);
_reSin10 := SIN(_reA10 * _crePI / 180.0);
_reSin01 := SIN(_reA01 * _crePI / 180.0);
_reSin11 := SIN(_reA11 * _crePI / 180.0);

_reCos00 := COS(_reA00 * _crePI / 180.0);
_reCos10 := COS(_reA10 * _crePI / 180.0);
_reCos01 := COS(_reA01 * _crePI / 180.0);
_reCos11 := COS(_reA11 * _crePI / 180.0);

(* Bilineare Interpolation *)
_reSinInterp := (1.0 - _reFx) * (1.0 - _reFy) * _reSin00
              + _reFx          * (1.0 - _reFy) * _reSin10
              + (1.0 - _reFx)  * _reFy          * _reSin01
              + _reFx          * _reFy           * _reSin11;

_reCosInterp := (1.0 - _reFx) * (1.0 - _reFy) * _reCos00
              + _reFx          * (1.0 - _reFy) * _reCos10
              + (1.0 - _reFx)  * _reFy          * _reCos01
              + _reFx          * _reFy           * _reCos11;

(* Vektor → Winkel in Grad *)
GetAngleInterp := FC_ATAN2(
                    xreY := _reSinInterp,
                    xreX := _reCosInterp)
                  * 180.0 / _crePI;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>