<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="FB_CollisionAvoidanceV3_4" Id="{b9c45e60-da4e-4fbe-aa18-e61151a2fc88}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_CollisionAvoidanceV3_4
VAR_INPUT
    xrePosX        : REAL;
    xrePosY        : REAL;
    xreOwnAngle    : REAL;
    xreOwnSpeed    : REAL;
    xreRobotX      : ARRAY[0..2] OF REAL;
    xreRobotY      : ARRAY[0..2] OF REAL;
    xboRobotActive : ARRAY[0..2] OF BOOL;
	xinOwnID : INT;
END_VAR
VAR_OUTPUT
    yreDynGx           : REAL;
    yreDynGy           : REAL;
    yboStop            : BOOL;
    yboWarning         : BOOL;
    yreMinDist         : REAL;
    yreSpeedFactor     : REAL;
    yreNearestRobotDir : REAL;
	yreAusgangsTest : REAL;
END_VAR
VAR
    _inIdx         : INT;
    _reDiffX       : REAL;
    _reDiffY       : REAL;
    _reDist        : REAL;
    _reRepulse     : REAL;
    _reNearestDist : REAL;
	
	
	rToleranz        : REAL := 5.0; (* Dein "Bereich", z.B. 5 Grad *)
    rDifferenz       : REAL;
    bImBereich       : BOOL;
	
	
	_reToOtherX   : REAL;
_reToOtherY   : REAL;
	_reCross      : REAL;
_reFrontal    : REAL;
_rePerpX      : REAL;
_rePerpY      : REAL;
_rePerpWeight : REAL;
_aboPerpActive : ARRAY[0..2] OF BOOL;   (* Latch pro Roboter *)

    (* Lokale Koordinaten für Bias *)
    _reOwnRad      : REAL;
    _reFwdX        : REAL;
    _reFwdY        : REAL;
    _reRightX      : REAL;
    _reRightY      : REAL;
    _reLong        : REAL;
    _reLat         : REAL;

    (* ── Tuning — nur diese 6 Parameter ───────────── *)
    _creRepulseRad  : REAL := 60.0;   (* Wirkradius in cm                  *) //70  alt aber weit entfernt    50 ziemlich dicht aber langsam
    _creRepulseK    : REAL := 3000.0; (* Abstoßungskraft                   *)
    _creStopDist    : REAL := 20.0;   (* Notstopp in cm                    *)
    _creWarnDist    : REAL := 45.0;   (* Warnung in cm                     *) //macht glaube nichts ???
    _creSlowDist    : REAL := 100.0;   (* Abbremsen ab hier                 *)
    _creRightBias   : REAL := 1.5;   (* Rechtsversatz 0=kein Bias, 1=viel *)

END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* ── Reset ─────────────────────────────────────────── *)
yreDynGx           := 0.0;
yreDynGy           := 0.0;
yboStop            := FALSE;
yboWarning         := FALSE;
yreMinDist         := 9999.0;
yreSpeedFactor     := 1.0;
yreNearestRobotDir := 0.0;
_reNearestDist     := 9999.0;

(* ── Fahrtrichtung ──────────────────────────────────── *)
_reOwnRad := xreOwnAngle * 3.14159265 / 180.0;
_reFwdX   :=  COS(_reOwnRad);
_reFwdY   :=  SIN(_reOwnRad);
_reRightX :=  SIN(_reOwnRad);
_reRightY := -COS(_reOwnRad);

FOR _inIdx := 0 TO 2 DO
    IF NOT xboRobotActive[_inIdx] THEN CONTINUE; END_IF

    (* ── Abstand ───────────────────────────────────── *)
    _reDiffX := xrePosX - xreRobotX[_inIdx];
    _reDiffY := xrePosY - xreRobotY[_inIdx];
    _reDist  := SQRT(_reDiffX * _reDiffX + _reDiffY * _reDiffY);

    IF _reDist < 0.1 THEN CONTINUE; END_IF

    (* ── Nächsten Roboter ───────────────────────────── *)
    IF _reDist < _reNearestDist THEN
        _reNearestDist     := _reDist;
        yreMinDist         := _reDist;
        yreNearestRobotDir := FC_ATAN2(
                                xreY := -_reDiffY,
                                xreX := -_reDiffX)
                              * 180.0 / 3.14159265;
    END_IF

    (* ── Zonen ─────────────────────────────────────── *)
    IF _reDist < _creStopDist  THEN yboStop    := TRUE; END_IF
    IF _reDist < _creWarnDist  THEN yboWarning := TRUE; END_IF

    (* ── Geschwindigkeitsreduktion ─────────────────── *)
    IF _reDist < _creSlowDist THEN
        IF _reDist <= _creStopDist THEN
            yreSpeedFactor := 0.0;
        ELSE
            yreSpeedFactor := MIN(
                yreSpeedFactor,
                (_reDist - _creStopDist) /
                (1 * _creSlowDist - _creStopDist));
        END_IF
    END_IF

    (* ── Latch-Reset: erst wenn deutlich außerhalb Wirkradius ── *)
    IF _reDist > _creRepulseRad * 1.5 THEN
        _aboPerpActive[_inIdx] := FALSE;
    END_IF

    (* ── Außerhalb Wirkradius: kein Repulse ─────────── *)
    IF _reDist > _creRepulseRad THEN CONTINUE; END_IF

    (* ── Projektion auf Fahrtrichtung ───────────────── *)
    _reLong := -(_reDiffX * _reFwdX   + _reDiffY * _reFwdY);
    _reLat  := -(_reDiffX * _reRightX + _reDiffY * _reRightY);

    (* ── Abstoßungskraft ────────────────────────────── *)
    IF _reLong < 0.0 THEN
        _reRepulse := (_creRepulseK / MAX(_reDist * _reDist, 1.0)) * 0.5;
    ELSE
        _reRepulse := _creRepulseK / MAX(_reDist * _reDist, 1.0);
    END_IF

    (* ── Geschwindigkeit skaliert Kraft ─────────────── *)
    _reRepulse := MAX(_reRepulse *
                  (1.0 + (xreOwnSpeed / 80.0) * 0.8), 1.2);

    (* ── Abstoßungsvektor in Weltkoordinaten ────────── *)
    yreDynGx := yreDynGx + _reRepulse * _reDiffX / _reDist;
    yreDynGy := yreDynGy + _reRepulse * _reDiffY / _reDist;

    (* ══════════════════════════════════════════════════
       SEITLICHE ABLENKUNG MIT HYSTERESE-LATCH
       SET:   Roboter ist vor uns (_reLong > 0)
       AKTIV: solange Latch gesetzt, unabhängig von _reLong
       RESET: erst wenn Abstand > _creRepulseRad * 1.5
       ══════════════════════════════════════════════════ *)

    (* SET: Roboter erkennbar vor uns *)
    IF _reLong > 0.0 THEN
        _aboPerpActive[_inIdx] := TRUE;
    END_IF

    IF _aboPerpActive[_inIdx] THEN

        (* Einheitsvektoren: Richtung vom eigenen Roboter zum anderen *)
        _reToOtherX := -_reDiffX / _reDist;
        _reToOtherY := -_reDiffY / _reDist;

        (* Kreuzprodukt Z: eigener Fahrvektor × Richtung-zum-anderen  *)
        (* > 0: anderer Roboter rechts  -> wir weichen links aus       *)
        (* < 0: anderer Roboter links   -> wir weichen rechts aus      *)
        _reCross := _reFwdX * _reToOtherY - _reFwdY * _reToOtherX;

        (* Wie frontal ist die Begegnung?                              *)
        (* 1.0 = exakt frontal, 0.0 = seitlich vorbei                 *)
        _reFrontal := _reFwdX * _reToOtherX + _reFwdY * _reToOtherY;
        _reFrontal := MAX(0.0, _reFrontal);

        (* Senkrechter Vektor, Richtung per Kreuzprodukt               *)
        (* Tiebreaker per RoboterID bei exakt symmetrischem Frontalfall*)
        IF ABS(_reCross) < 0.15 THEN
            (* Exakt frontal: ID-basierte feste Seite -> kein Deadlock *)
            IF xinOwnID MOD 2 = 0 THEN
                _rePerpX :=  _reToOtherY;
                _rePerpY := -_reToOtherX;
            ELSE
                _rePerpX := -_reToOtherY;
                _rePerpY :=  _reToOtherX;
            END_IF
        ELSIF _reCross >= 0.0 THEN
            (* Anderer rechts -> links ausweichen *)
            _rePerpX := -_reToOtherY;
            _rePerpY :=  _reToOtherX;
        ELSE
            (* Anderer links -> rechts ausweichen *)
            _rePerpX :=  _reToOtherY;
            _rePerpY := -_reToOtherX;
        END_IF

        (* Gewichtung: je frontaler, desto stärker der Perp-Anteil    *)
        _rePerpWeight := _reFrontal * _reRepulse * _creRightBias;

        yreDynGx := yreDynGx + _rePerpX * _rePerpWeight;
        yreDynGy := yreDynGy + _rePerpY * _rePerpWeight;

    END_IF

END_FOR

yreAusgangsTest := _reRepulse;

IF yboStop THEN yreSpeedFactor := 0.0; END_IF]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>