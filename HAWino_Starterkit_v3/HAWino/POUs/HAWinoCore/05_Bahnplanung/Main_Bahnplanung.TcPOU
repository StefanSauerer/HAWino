<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="Main_Bahnplanung" Id="{44fc9111-07c7-42f2-9fb5-03f7fc5fe448}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN_Bahnplanung
VAR
    (* 13 Kartenbausteine — jeder hält sein eigenes Array *)
    arfbMaps       : ARRAY[1..14] OF FB_AngleMap;
    fbNav          : FB_Navigation;
	//fbStates	   : FB_StatesTest;
	fbStates : FB_RobotStateMachine;
	fb_mapping : FB_Mapping;
	fb_MQTT : FB_MQTTNeu;//FB_MQTT;

	
    (* Ladesteuerung *)
    inLoadIdx      : INT := 1;
    boAllLoaded    : BOOL := FALSE;
    boLoadError    : BOOL := FALSE;

    (* Navigation *)
    rePosX         : REAL := 180.0;
    rePosY         : REAL :=  20.0;
    inActiveGoal   : INT  :=   3;

    areRobotX      : ARRAY[0..2] OF REAL;
    areRobotY      : ARRAY[0..2] OF REAL;
    aboRobotActive : ARRAY[0..2] OF BOOL;

    reAngleTarget  : REAL;
    reDistToGoal   : REAL;
	reDistFromGoal : REAL;
	reSpeed 	   : REAL;
    boAtGoal       : BOOL;
    boStop         : BOOL;
    boNavError     : BOOL;
	boIdle			: BOOL;
	RobotIndex: INT;
	actualPosX: LREAL;
	actualPosY: LREAL;
	actualPosTheta: LREAL;
	actualError: LREAL;
	boWarning: BOOL;
	reMinDist: REAL;
	sMqttIn : sMqttIn;
	sMqttOut : sMqttOut;
	eStateMachine : E_RobotState;
	sactualKoordinates : sKoordinate;
	lightBarrierGripper AT %I* : BOOL;
	inMqttTokenTargetId : INT;
	_boAwayFromObstacle : BOOL;
	_boPasssiveWait : BOOL;
	_boMovingAway : BOOL;
	_boCharging : BOOL;
	_inChargingStation : INT;
END_VAR
	
	VAR_TEMP
    tinI : INT; // Temporary variable
	tinJ : INT := 0;
	tarstHAWId: ARRAY[0..29] OF sKoordinate;
	tinSourceIndex          : INT;                          // Array index of source station  (0..21)
    tinTargetIndex          : INT;                          // Array index of target station  (0..21)
    tinRfidSourceIndex      : INT;                          // Array index of RFID point at source (22..29)
    tinRfidTargetIndex      : INT;                          // Array index of RFID point at target (22..29)
    tinParkingIndex         : INT;                          // Array index of parking position (16..19)
    tinChargingIndex        : INT;                          // Array index of charging station (20..21)
	tinMapSource            : INT;                          // Map ID for source station
    tinMapTarget            : INT;                          // Map ID for target station
    tinMapParking           : INT;                          // Map ID for parking position
	tinTargetDirectionIndex : INT;							//
	tinSourceDirectionIndex : INT;
	tinChargingStatus		: INT;
	
					
	END_VAR
	
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT boAllLoaded AND NOT boLoadError THEN

    (* Aktuellen Baustein laden *)
    arfbMaps[inLoadIdx](
        xinGoalID := inLoadIdx,
        xboLoad   := TRUE);

    (* Auf Fehler prüfen *)
    IF arfbMaps[inLoadIdx].yboError THEN
        boLoadError := TRUE;
        RETURN;
    END_IF

    (* Wenn fertig: nächste Karte *)
    IF arfbMaps[inLoadIdx].yboDone THEN
        IF inLoadIdx < 14 THEN
            inLoadIdx := inLoadIdx + 1;
        ELSE
            boAllLoaded := TRUE;
        END_IF
    END_IF

    RETURN;   (* Erst navigieren wenn alle Karten geladen *)
END_IF

RobotIndex := Var_HAWIno.Robot_Number;
IF (RobotIndex < 1) OR (RobotIndex > 4) THEN
	// Falls außerhalb Bereich: Default auf 1 setzen 
	RobotIndex := -1;
ELSE
	actualPosX 		:= Camera.cameraData.robotPosition[RobotIndex].x;
	actualPosY 		:= Camera.cameraData.robotPosition[RobotIndex].y;
	actualPosTheta 	:= Camera.cameraData.robotPosition[RobotIndex].theta;
	actualError		:= Camera.cameraData.robotPosition[RobotIndex].e;
END_IF;

FOR tinI := 1 TO 4 BY 1 DO
	IF NOT (RobotIndex = tinI) THEN
   areRobotX[tinJ] := LREAL_TO_REAL(Camera.cameraData.robotPosition[tinI].x) / 10;
   areRobotY[tinJ] := LREAL_TO_REAL(Camera.cameraData.robotPosition[tinI].y) / 10;
   tinJ := tinJ + 1;
   END_IF
END_FOR

FOR tinJ := 0 TO 2 BY 1 DO
IF areRobotX[tinJ] = 0 AND areRobotY[tinJ] = 0 THEN
	aboRobotActive[tinJ] := FALSE;
	ELSE 
		aboRobotActive[tinJ] := TRUE;
	END_IF
END_FOR

sactualKoordinates.rePosX := actualPosX / 10;
sactualKoordinates.rePosY := actualPosY / 10;
sactualKoordinates.reWinkel := actualPosTheta;



fb_MQTT(xsDataToSend := sMqttOut,
	xsKoordinate :=  sactualKoordinates,
	xboCharging := _boCharging,
	xinChargingPoint := _inChargingStation,
	ysDataToReceive => sMqttIn,
	xinMqttTokenTargetId := inMqttTokenTargetId,
	yinchargingstatus => tinChargingStatus);

(*fbStates (xboVectorTargetReached := boAtGoal,
 xinSatus := GVL_Datatransfer23.inStatus,
 yinControl => GVL_Datatransfer23.inControl,
 ysTargetPosition => GVL_Datatransfer23.gvZielPosition,
 yinTargetMap => inActiveGoal);
*)	
	
	sMqttOut.sJobState.boWorkpieceLoaded := NOT lightBarrierGripper; //TODO Confirm WITH EBEL
	
fb_mapping(
    xstMqttIn              := sMqttIn,
    xinDefaultParkingIndex := IDX_PARKING_101,
	yinSourceDirectionIndex => tinSourceDirectionIndex,
	yinTargetDirectionIndex => tinTargetDirectionIndex,
    yinSourceIndex => tinSourceIndex,
    yinTargetIndex => tinTargetIndex,
    yinRfidSourceIndex => tinRfidSourceIndex,
    yinRfidTargetIndex => tinRfidTargetIndex,
    yinParkingIndex => tinParkingIndex,
    yinChargingIndex => tinChargingIndex,
    yinMapSource => tinMapSource,
    yinMapTarget => tinMapTarget);
	
	
	
CASE RobotIndex OF 
	1:tarstHAWId := arstHAWino1;
	2:tarstHAWId := arstHAWino2;
	3:tarstHAWId := arstHAWino3;
	4:tarstHAWId := arstHAWino4;
END_CASE
	
fbStates (xstMqttIn := sMqttIn, xeRobotStatus := GVL_Datatransfer23.inStatus, 
xboMapsLoaded := boAllLoaded, 
xboVectorTargetReached := boAtGoal, 
xarstCoordinates := tarstHAWId,
xinSourceIndex := tinSourceIndex,
xinSourceDirectionIndex := tinSourceDirectionIndex,
xinTargetDirectionIndex := tinTargetDirectionIndex,
xinTargetIndex := tinTargetIndex,         
xinRfidSourceIndex := tinRfidSourceIndex,
xinRfidTargetIndex := tinRfidTargetIndex,
xinParkingIndex := tinParkingIndex,
xinChargingIndex := tinChargingIndex,
xinMapSource := tinMapSource,
xinMapTarget := tinMapTarget,
xinMapParking := tinParkingIndex,//tinMapParking,
xreDistToGoal := reDistToGoal,
xreDistFromGoal := reDistFromGoal, 
xboWSSensor := NOT lightBarrierGripper,
xboAwayFromObstacle := _boAwayFromObstacle,
xinStatusOfChargin := tinChargingStatus, 
yeControl => GVL_Datatransfer23.inControl,
ystTargetPosition => GVL_Datatransfer23.gvZielPosition,
yinTargetMap => inActiveGoal,
ystMqttOut => sMqttOut,
yeCurrentState => eStateMachine,
yeMqttTokenTargetId => inMqttTokenTargetId,
yboDriveAway => _boMovingAway,
yboPassiveWait => _boPasssiveWait,
yboCharging => _boCharging,
yinCharginStationID => _inChargingStation);


reSpeed := 300;
(* ── Navigation ────────────────────────────────────── *)
fbNav(
    xrePosX        := GVL_Datatransfer23.gvActualPosition.reX / 10,
    xrePosY        := GVL_Datatransfer23.gvActualPosition.reY / 10,
    xinGoalID      := inActiveGoal,
    xreRobotX      := areRobotX,
    xreRobotY      := areRobotY,
    xboRobotActive := aboRobotActive,
	xboDriveAway   := _boMovingAway,
	xboPassiveWait := _boPasssiveWait,
    xyarMaps       := arfbMaps,
    yreAngleTarget => reAngleTarget,
    yreDistToGoal  => reDistToGoal,
	yreDistToOldGoal => reDistFromGoal,
    yboAtGoal      => boAtGoal,
    yboStop        => boStop,
	yboWarning     => boWarning,
	yboIdle 		=> boIdle,
    yreMinDist     => reMinDist,
    yboError       => boNavError,
	yboAwayFromStation => _boAwayFromObstacle);
	
	reAngleTarget := - reAngleTarget;
	IF reDistToGoal < 30 THEN //TODO FINETUNE
		reSpeed := MAX(reSpeed * reDistToGoal /30,  100);
	END_IF
	
	IF boAtGoal THEN 
		reSpeed := 0;
	END_IF
	IF _boMovingAway THEN
		reSpeed := 150;
	END_IF
	IF boIdle THEN
		GVL_Datatransfer23.inControl := RobotControl.idle;
	END_IF
	
	GVL_Datatransfer23.gvFahrvektor.reGeschwindigkeit := reSpeed;
	GVL_Datatransfer23.gvFahrvektor.reWinkel :=  reAngleTarget;

	]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>