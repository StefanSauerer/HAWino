<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="FB_Navigation" Id="{47de1444-cb17-492a-8a9c-9d58d0e140ab}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Navigation
VAR_INPUT
    xrePosX        : LREAL;
    xrePosY        : LREAL;
    xinGoalID      : INT;
    xreRobotX      : ARRAY[0..2] OF REAL;
    xreRobotY      : ARRAY[0..2] OF REAL;
    xboRobotActive : ARRAY[0..2] OF BOOL;
END_VAR
VAR_OUTPUT
    yreAngleTarget : REAL;
    yreDistToGoal  : REAL;
    yboAtGoal      : BOOL;
    yboStop        : BOOL;
    yboError       : BOOL;
    yboWarning     : BOOL;
    yreMinDist     : REAL;
END_VAR
VAR_IN_OUT
    (* Referenz auf die 13 Kartenbausteine — von außen übergeben *)
    xyarMaps : ARRAY[1..13] OF FB_AngleMap;
END_VAR
VAR
	_fbCollision   : FB_CollisionAvoidance;
    _inPosX        : INT;
    _inPosY        : INT;
    _reRawAngle    : REAL;
    _reStatGx      : REAL;
    _reStatGy      : REAL;
    _reDynGx       : REAL;
    _reDynGy       : REAL;
    _reTotalGx     : REAL;
    _reTotalGy     : REAL;
    _reDiffX       : REAL;
    _reDiffY       : REAL;
    _reDist        : REAL;
    _reDistSq      : REAL;
	_reLastAngle   : REAL := 0.0;
	_reDelta       : REAL;
    _reAngleRaw    : REAL;
    _inIdx         : INT := 0;
    _crePI         : REAL := 3.14159265358979;
    _creRepulseK   : REAL := 1000.0;
    _creRepulseRad : REAL := 500.0;
    _creStopDist   : REAL := 5.0;
    _creGoalRadius : REAL := 5.0;
	_creMaxDeltaDeg: REAL := 2.0;   (* max. Winkeländerung pro Zyklus *)
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[
(* ── Eingaben prüfen ───────────────────────────────── *)
IF xinGoalID < 1 OR xinGoalID > 13 THEN
    yboError := TRUE; RETURN;
END_IF
IF NOT xyarMaps[xinGoalID].yboDone THEN
    yboError := TRUE; RETURN;
END_IF
yboError := FALSE;

(* ── 1) Abstand zum Ziel ───────────────────────────── *)
_reDiffX      := xrePosX - GVL_Maps.sreGoalX[xinGoalID];
_reDiffY      := xrePosY - GVL_Maps.sreGoalY[xinGoalID];
yreDistToGoal := SQRT(_reDiffX * _reDiffX + _reDiffY * _reDiffY);

(* ── 2) Ziel erreicht? ─────────────────────────────── *)
IF yreDistToGoal <= _creGoalRadius THEN
    yboAtGoal      := TRUE;
    yreAngleTarget := 0.0;
    RETURN;
END_IF
yboAtGoal := FALSE;

(* ── 3) Koordinaten begrenzen ──────────────────────── *)
_inPosX := REAL_TO_INT(TRUNC(xrePosX));
_inPosY := REAL_TO_INT(TRUNC(xrePosY));
_inPosX := MAX(0, MIN(_inPosX, 799));
_inPosY := MAX(0, MIN(_inPosY, 399));

(* ── 4) Hindernischeck ─────────────────────────────── *)
IF xyarMaps[xinGoalID].GetAngle(
       xinPosX := _inPosX,
       xinPosY := _inPosY) = -9999 THEN
    yboStop := TRUE; RETURN;
END_IF

(* ── 5) Winkel interpoliert aus Karte ──────────────── *)
_reRawAngle := xyarMaps[xinGoalID].GetAngleInterp(
                   xrePosX := xrePosX,
                   xrePosY := xrePosY);

_reStatGx := COS(_reRawAngle * _crePI / 180.0);
_reStatGy := SIN(_reRawAngle * _crePI / 180.0);

(* ── 6) Kollisionsvermeidung ───────────────────────── *)
_fbCollision(
    xrePosX        := xrePosX,
    xrePosY        := xrePosY,
    xreRobotX      := xreRobotX,
    xreRobotY      := xreRobotY,
    xboRobotActive := xboRobotActive);

yboWarning := _fbCollision.yboWarning;
yreMinDist := _fbCollision.yreMinDist;

(* ── 7) Notstopp ───────────────────────────────────── *)
IF _fbCollision.yboStop THEN
    yboStop        := TRUE;
    yreAngleTarget := THIS^.LimitAngleRate(
                        xreAngleRaw    := _reRawAngle,
                        xreMaxDeltaDeg := _creMaxDeltaDeg);
    RETURN;
END_IF
yboStop := FALSE;

(* ── 8) Superposition ──────────────────────────────── *)
_reTotalGx := _reStatGx + _fbCollision.yreDynGx;
_reTotalGy := _reStatGy + _fbCollision.yreDynGy;

(* ── 9) Winkelberechnung + Rate Limiter ────────────── *)
IF SQRT(_reTotalGx * _reTotalGx + _reTotalGy * _reTotalGy) < 0.001 THEN
    yreAngleTarget := THIS^.LimitAngleRate(
                        xreAngleRaw    := _reRawAngle,
                        xreMaxDeltaDeg := _creMaxDeltaDeg);
ELSE
    yreAngleTarget := THIS^.LimitAngleRate(
                        xreAngleRaw    := FC_ATAN2(
                                            xreY := _reTotalGy,
                                            xreX := _reTotalGx)
                                          * 180.0 / _crePI,
                        xreMaxDeltaDeg := _creMaxDeltaDeg);
END_IF]]></ST>
    </Implementation>
    <Method Name="LimitAngleRate" Id="{5edcd3af-84e9-4477-be83-105752146b33}">
      <Declaration><![CDATA[METHOD LimitAngleRate : REAL
VAR_INPUT
    xreAngleRaw     : REAL;   (* neuer ungbegrenzter Winkel *)
    xreMaxDeltaDeg  : REAL;   (* max. Änderung pro Zyklus   *)
END_VAR
VAR
    _reDelta : REAL;
    _reResult: REAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF _reLastAngle = 0 THEN
	_reLastAngle := xreAngleRaw;
END_IF

(* ── Winkeldifferenz berechnen ─────────────────────── *)
_reDelta := xreAngleRaw - _reLastAngle;

(* ── Auf [-180, +180] normieren ────────────────────── *)
WHILE _reDelta > 180.0 DO
    _reDelta := _reDelta - 360.0;
END_WHILE
WHILE _reDelta < -180.0 DO
    _reDelta := _reDelta + 360.0;
END_WHILE

(* ── Änderung begrenzen ─────────────────────────────── *)
IF _reDelta > xreMaxDeltaDeg THEN
    _reDelta := xreMaxDeltaDeg;
ELSIF _reDelta < -xreMaxDeltaDeg THEN
    _reDelta := -xreMaxDeltaDeg;
END_IF

(* ── Neuen Winkel berechnen ─────────────────────────── *)
_reResult := _reLastAngle + _reDelta;

(* ── Auf [-180, +180] halten ────────────────────────── *)
IF _reResult > 180.0 THEN
    _reResult := _reResult - 360.0;
ELSIF _reResult < -180.0 THEN
    _reResult := _reResult + 360.0;
END_IF

(* ── Für nächsten Zyklus speichern ─────────────────── *)
_reLastAngle := _reResult;

LimitAngleRate := _reResult;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>