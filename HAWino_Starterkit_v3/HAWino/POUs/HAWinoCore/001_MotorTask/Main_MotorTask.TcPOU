<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="Main_MotorTask" Id="{c0f79474-5394-49ee-95a0-09a934fd6952}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM Main_MotorTask
VAR
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Variablen, die zur Synchronisation über das PAI (Prozessabbild) in den Task geladen werden.
	// -> Die Variablen werden von anderen Tasks gesetzt und müssen in den Task In/Outputs verknüpft werden
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Inputs für die Regelung
	n1fromMotor AT%I* : UINT; //Geschwindigkeit von der Motorklemme über den InfoData Kanal
	n2fromMotor AT%I* : UINT;
	n3fromMotor AT%I* : UINT;
	currentfromMotor1 AT %I* : UINT;	//Strom von der Motorklemme über den InfoData Kanal 2
	currentfromMotor2 AT %I* : UINT;
	currentfromMotor3 AT %I* : UINT;
	sliderGripper 		AT %I* : BOOL;

	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Variablen werden zur Synchronisation über das PA-Q aus dem Task gesetzt.
	// -> Die Variablen werden von anderen Tasks gelesen.
	//////////////////////////////////////////////////////////////////////////////////////////////////////////

	// Freigabe der Motoren
	enableToMotor1 AT%Q*:BOOL:=FALSE;
	enableToMotor2 AT%Q*:BOOL:=FALSE;
	enableToMotor3 AT%Q*:BOOL:=FALSE;
	// Sollwerte der Motoren
	velocityToMotor1 AT%Q*:INT:=0;
	velocityToMotor2 AT%Q*:INT:=0;
	velocityToMotor3 AT%Q*:INT:=0;
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Taskinterne Inputs
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Wheel-Encoder Daten
	wheelEncoderLocalVx AT%I*		:LREAL;
	wheelEncoderLocalVy AT%I*		:LREAL;
	wheelEncoderLocalVtheta AT%I*	:LREAL;
	// Bumper Daten
	bumper AT%I* : BOOL;
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Lokale Variablen
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	
	// Übergabevariablen vom Lageregler zum Drehzahlregler
	vXCartesianToMotors 	:	LREAL;
	vYCartesianToMotors 	:	LREAL;
	vThetaCartesianToMotors :	LREAL;
	
	// Reglerdaten
	Motor1current: INT;
	Motor2current: INT;
	Motor3current: INT;

	velWheel1: LREAL;
	velWheel2: LREAL;
	velWheel3: LREAL;
	
	maxMotorRPM 			: INT 	:= 3600; 		// in rpm 
	maxKlemmeDrehzahlMessung: LREAL := 10000; 		// Bei Maximaldrehzahl zurückgegebener Drehzahlwert der Motorklemme
	rWheel 					: INT 	:= 40; 			// in mm
	ue						: LREAL := 0.0625; 		// Getriebeuebersetzung 
	cycletime 				: LREAL	:= 0.00033333; 	// Cycletime des Motortasks
	enableMotorControl		: BOOL  := TRUE;
	
	RobotIndex : INT := -1;
	
	DeltaWinkel : LREAL := 0.0;
	DeltaX : LREAL := 0.0;
	DeltaY : LREAL := 0.0;
	
	DeltaIn     : LREAL;
	DeltaLat    : LREAL;
	PosInOK     : BOOL;
	PosLatOK    : BOOL;
	
	WinkelOK: BOOL := FALSE;
	
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Instanzierung der FBs
	//////////////////////////////////////////////////////////////////////////////////////////////////////////

	FB_Drehzahlregler 	: FB_Drehzahlregler;	//Gilt für alle drei Motoren
	FB_Positionsregler 	: FB_Positionsregler;
	
	
	targetSpeed_World 	: sPosition;	// Geschwindigkeit in Weltkoordinaten
	targetSpeed_Robot	: sPosition;	// Geschwindigkeit in Roboterkoordinaten
	targetPos			: sPosition;	// Geschwindigkeitsvorgabe
	actualPos			: sPosition;	// Tatsächliche Position

	perfCamPos			: sPosition :=  (reWinkel := 0, reX := 0, reY := 0);	// vorherige Kamera Position

	VelAngle : LREAL; //Winkel in dem der Roboter fährt	
	IR_Distance : LREAL; // Minimaler Abstand des IR Sensors in Fahrtrichtung
	
	//Pseudofuzzy Parameter
	// Ersetzt die alten KPX_MIN/MAX etc. - umbenannt + gespiegelt für Lateral
	NILL        : LREAL := 0.0;
	
	KP_IN_MIN   : LREAL := 0.1;    // Einfahrrichtung KP minimum
	KP_IN_MAX   : LREAL := 3.0;    // Einfahrrichtung KP maximum
	KP_LAT_MIN  : LREAL := 1.0;    // Querrichtung KP minimum
	KP_LAT_MAX  : LREAL := 2.0;    // Querrichtung KP maximum
	KI_IN_MIN   : LREAL := 0.0;    // Einfahrrichtung KI disabled
	KI_IN_MAX   : LREAL := 0.25;    // Einfahrrichtung KI maximum
	
	// Berechnete Reglerwerte (generisch)
	KP_In       : LREAL;
	KP_Lat      : LREAL;
	KI_In       : LREAL;
	
	// Regler-Eingangswerte (gemappt auf X/Y des FB-Interfaces)
	KPX         : LREAL;
	KPY         : LREAL;
	KIX         : LREAL;
	KIY 		: LREAL;
	
	
	// Nil-Durchschaltung für gesperrte Achse
	vNILL_X     : LREAL := 0.0;    // Wird NILL zugewiesen wenn X gesperrt
	vNILL_Y     : LREAL := 0.0;    // Wird NILL zugewiesen wenn Y gesperrt
	
	ePocketOrientation : (ePocketX := 0, ePocketY := 1);
	
	f : LREAL;//Funktion für Übergang KIX und KPX
	
	wheelSpeed 			: WheelVelocity;
	

	diffPos		: sPosition;
	
	distanzeToRobot : LREAL;	// Abstandssensoren in mm
	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[//Umrechung der Klemmenwerte
ACT_Drehzahlerfassung();

/////////////////////////////////////////////////////////////////////////////////////////////////////////
// Roboter-Positions-Bestimmung 
/////////////////////////////////////////////////////////////////////////////////////////////////////////
RobotIndex := Var_HAWIno.Robot_Number;
IF (RobotIndex < 1) OR (RobotIndex > 4) THEN
	// Falls außerhalb Bereich: Default auf 1 setzen 
	RobotIndex := -1;
ELSE

	wheelSpeed.wheel1  := -velWheel1;
	wheelSpeed.wheel2  := -velWheel2;
	wheelSpeed.wheel3  := -velWheel3;
	Beobachter(wheelSpeed := wheelSpeed, cameraData := Camera.cameraData, RobotIndex := RobotIndex, eastPos => actualPos);
	//enableMotorControl := FALSE;	
END_IF;

// Beste Positionsschätzung an Gruppe 2 übergeben
GVL_Datatransfer23.gvActualPosition		:= actualPos;


// Bei Bumper in den Fehler gehen
IF bumper THEN
	enableMotorControl := FALSE;
	GVL_Datatransfer23.inStatus := RobotStatus.fehler;	
END_IF

// Wenn keine Anfangsposition der Kamera gefunden wurde und der Roboter los fahren soll in den Fehlerzustand gehen
IF (actualPos.reX = 0 AND actualPos.reY = 0 AND  actualPos.reWinkel = 0) THEN
	IF GVL_Datatransfer23.inControl = RobotControl.vector OR  GVL_Datatransfer23.inControl = RobotControl.position THEN
		// enableMotorControl := FALSE;
		GVL_Datatransfer23.inStatus := RobotStatus.fehler;	
	END_IF
END_IF


/////////////////////////////////////////////////////////////////////////////////////////////////////////
// Schrittkette
/////////////////////////////////////////////////////////////////////////////////////////////////////////
CASE GVL_Datatransfer23.inControl OF 
	RobotControl.idle:
		targetSpeed_Robot.reX		:= 0;
		targetSpeed_Robot.reY		:= 0;
		targetSpeed_Robot.reWinkel	:= 0;
		enableMotorControl := TRUE;
		GVL_Datatransfer23.inStatus	:= RobotStatus.betriebsbereit;

	RobotControl.stop:
		targetSpeed_Robot.reX		:= 0;
		targetSpeed_Robot.reY		:= 0;
		targetSpeed_Robot.reWinkel	:= 0;
		enableMotorControl := FALSE;
		GVL_Datatransfer23.inStatus	:= RobotStatus.fehler;
		
	RobotControl.reset:
		targetSpeed_Robot.reX		:= 0;
		targetSpeed_Robot.reY		:= 0;
		targetSpeed_Robot.reWinkel	:= 0;
		enableMotorControl := TRUE;
		GVL_Datatransfer23.inStatus	:= RobotStatus.betriebsbereit;
		
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Vector Regelung
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	RobotControl.vector:	
		// Geschwindigkeitsvektor von Gruppe 2 in Weltkoordinaten umrechnen
		targetSpeed_World.reX 	:= 		 GVL_Datatransfer23.gvFahrvektor.reGeschwindigkeit * COS(GVL_Datatransfer23.gvFahrvektor.reWinkel * PI /180.0);
		targetSpeed_World.reY 	:= (-1)* GVL_Datatransfer23.gvFahrvektor.reGeschwindigkeit * SIN(GVL_Datatransfer23.gvFahrvektor.reWinkel * PI /180.0);
		targetSpeed_World.reWinkel := 0;	// Zielwinkel in der Vectorregelung immer auf 0 setzen
		
		// Umrechnung der Geschwindigkeit von Welt in Roboterkoordinaten
		targetSpeed_Robot.reX 		:= targetSpeed_World.reX * COS(actualPos.reWinkel) - targetSpeed_World.reY * SIN(actualPos.reWinkel);
		targetSpeed_Robot.reY 		:= targetSpeed_World.reY * COS(actualPos.reWinkel) + targetSpeed_World.reX * SIN(actualPos.reWinkel);

		targetSpeed_Robot.reWinkel 	:= targetSpeed_World.reWinkel;	
		
		//targetSpeed_Robot.reX 		:= 0;
		//targetSpeed_Robot.reY 		:= 100;
		
		// VelAngle in Grad, 0°=+X, 90°=+Y, 180°=-X, 270°=-Y (CCW)
		VelAngle := ATAN2(targetSpeed_Robot.reY, targetSpeed_Robot.reX);

		// Negativen Bereich auf 0–360° normieren
		IF VelAngle < 0.0 THEN
    		VelAngle := VelAngle + 360.0;
		END_IF;
		
		IR_Distance := GetMinDistance(velAngle := VelAngle, tolerance := 45.0);
		
		IF IR_Distance < 100 THEN
			targetSpeed_Robot.reX 	:= 0;
			targetSpeed_Robot.reY 	:= 0;
		END_IF
		
		
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Positions Regelung
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	RobotControl.position:	
		targetPos.reX 		:= GVL_Datatransfer23.gvZielPosition.reX;
		targetPos.reY 		:= GVL_Datatransfer23.gvZielPosition.reY;
		targetPos.reWinkel	:= GVL_Datatransfer23.gvZielPosition.reWinkel* PI / 180.0;;
		// Prüfen ob Zielpositon erreicht
		

		// --- Pocket Orientation automatisch ermitteln ---
		IF ABS(ABS(targetPos.reWinkel) - (3.14159 / 2.0)) < 0.2 THEN
			ePocketOrientation := ePocketY;
		ELSE
			ePocketOrientation := ePocketX;
		END_IF
		
		// --- Deltas berechnen ---
		DeltaWinkel := ABS(actualPos.reWinkel) - ABS(targetPos.reWinkel);
		DeltaX      := ABS(actualPos.reX - targetPos.reX);
		DeltaY      := ABS(actualPos.reY - targetPos.reY);
		
		// Einfahr- und Querrichtung mappen
		IF ePocketOrientation = ePocketX THEN
			DeltaIn  := DeltaX;
			DeltaLat := DeltaY;
		ELSE
			DeltaIn  := DeltaY;
			DeltaLat := DeltaX;
		END_IF
		
		// --- Status-Flags ---
		IF ABS(DeltaWinkel) < 0.2   THEN WinkelOK := TRUE;  ELSE WinkelOK := FALSE;  END_IF
		IF DeltaIn          < 12    THEN PosInOK  := TRUE;  ELSE PosInOK  := FALSE;  END_IF
		IF DeltaLat         < 2     THEN PosLatOK := TRUE;  ELSE PosLatOK := FALSE;  END_IF		
		
		// --- Adaptive Verstärkung (Einfahrrichtung) ---
		f := DeltaIn / 100.0;
		IF f > 1 THEN f := 1; END_IF
		IF f < 0 THEN f := 0; END_IF
		
		IF DeltaIn < 35 THEN
			KP_In := 0;
		ELSE
			KP_In := KP_IN_MIN + f * (KP_IN_MAX - KP_IN_MIN);
		END_IF
		
		IF DeltaIn > 100 THEN
			KI_In := 0;
		ELSE
			KI_In := KI_IN_MAX - f * (KI_IN_MAX - KI_IN_MIN);
		END_IF
		
		KP_Lat := KP_LAT_MAX;
		
		// --- KPX/KPY/KIX/KIY auf FB-Interface mappen ---
		IF ePocketOrientation = ePocketX THEN
			KPX := KP_In;
			KPY := KP_Lat;
			KIX := KI_In;
			KIY := NILL;     // Lateral-Integral nicht benötigt
		ELSE
			KPX := KP_Lat;   // FB-X ist Querrichtung
			KPY := KP_In;    // FB-Y ist Einfahrrichtung
			KIX := NILL;     // Lateral-Integral nicht benötigt
			KIY := KI_In;    // Integral liegt jetzt auf Y
		END_IF
		
		// --- Regleraufrufe ---
		
		// 1. Winkel ausrichten
		IF (WinkelOK = FALSE) THEN
			FB_Positionsregler(targetPos := targetPos, actualPos := actualPos,
								vXCartesianToMotors     => targetSpeed_Robot.reX,
								vYCartesianToMotors     => targetSpeed_Robot.reY,
								vThetaCartesianToMotors => targetSpeed_Robot.reWinkel);
								targetSpeed_Robot.reX := 0;
								targetSpeed_Robot.reY := 0;
			GVL_Datatransfer23.inStatus := RobotStatus.laufend;
		
		// 2. Nah an Tasche aber lateral daneben: nur Querrichtung
		ELSIF (DeltaLat > 5 AND DeltaIn < 20) THEN
			IF ePocketOrientation = ePocketX THEN
				FB_Positionsregler(targetPos := targetPos, actualPos := actualPos,
									KPX := NILL, KPY := KPY, KIX := NILL, KIY := NILL,
									vXCartesianToMotors     => targetSpeed_Robot.reX,
									vYCartesianToMotors     => targetSpeed_Robot.reY,
									vThetaCartesianToMotors => targetSpeed_Robot.reWinkel);
									targetSpeed_Robot.reX := 0;
			ELSE
				FB_Positionsregler(targetPos := targetPos, actualPos := actualPos,
									KPX := KPX, KPY := NILL, KIX := NILL, KIY := NILL,
									vXCartesianToMotors     => targetSpeed_Robot.reX,
									vYCartesianToMotors     => targetSpeed_Robot.reY,
									vThetaCartesianToMotors => targetSpeed_Robot.reWinkel);
									targetSpeed_Robot.reY := 0;
			END_IF
			GVL_Datatransfer23.inStatus := RobotStatus.laufend;
		
		// 3. Lateral nicht OK: Querrichtung bevorzugen, Einfahrt gedrosselt
		ELSIF (PosLatOK = FALSE) THEN
			IF ePocketOrientation = ePocketX THEN
				FB_Positionsregler(targetPos := targetPos, actualPos := actualPos,
								KPX := 0.2 * KPX, KPY := KPY, KIX := 0.2 * KIX, KIY := KIY,
								vXCartesianToMotors     => targetSpeed_Robot.reX,
								vYCartesianToMotors     => targetSpeed_Robot.reY,
								vThetaCartesianToMotors => targetSpeed_Robot.reWinkel);
			ELSE
				FB_Positionsregler(targetPos := targetPos, actualPos := actualPos,
								KPX := KPX, KPY := 0.1 * KPY, KIX := KIX, KIY := 0.1 * KIY,
								vXCartesianToMotors     => targetSpeed_Robot.reX,
								vYCartesianToMotors     => targetSpeed_Robot.reY,
								vThetaCartesianToMotors => targetSpeed_Robot.reWinkel);
			END_IF
			GVL_Datatransfer23.inStatus := RobotStatus.laufend;
		
		// 4. Normalbetrieb
		ELSIF (Gripper.slider = TRUE) THEN
			
			IF ePocketOrientation = ePocketX THEN
				FB_Positionsregler(targetPos := targetPos, actualPos := actualPos,
								KPX := KPX, KPY := KPY, KIX := KIX, KIY := KIY,
								vXCartesianToMotors     => targetSpeed_Robot.reX,
								vYCartesianToMotors     => targetSpeed_Robot.reY,
								vThetaCartesianToMotors => targetSpeed_Robot.reWinkel);
			ELSE
				FB_Positionsregler(targetPos := targetPos, actualPos := actualPos,
								KPX := KPX, KPY := KPY, KIX := KIX, KIY := 2*KIY,
								vXCartesianToMotors     => targetSpeed_Robot.reX,
								vYCartesianToMotors     => targetSpeed_Robot.reY,
								vThetaCartesianToMotors => targetSpeed_Robot.reWinkel);
			END_IF			
			GVL_Datatransfer23.inStatus := RobotStatus.laufend;
		
		// 5. Ziel erreicht
		ELSE
			FB_Positionsregler(targetPos := targetPos, actualPos := actualPos,
								vXCartesianToMotors     => targetSpeed_Robot.reX,
								vYCartesianToMotors     => targetSpeed_Robot.reY,
								vThetaCartesianToMotors => targetSpeed_Robot.reWinkel);
								targetSpeed_Robot.reY := 0;
								targetSpeed_Robot.reX := 0;
								targetSpeed_Robot.reWinkel := 0;
			GVL_Datatransfer23.inStatus := RobotStatus.zielErreicht;
		END_IF
	
	END_CASE
/////////////////////////////////////////////////////////////////////////////////////////////////////////
// Drehzahlregler
/////////////////////////////////////////////////////////////////////////////////////////////////////////
FB_Drehzahlregler(targetVelX			:= targetSpeed_Robot.reX,
					targetVelY 			:= targetSpeed_Robot.reY, 
					tragetVelTheta		:= targetSpeed_Robot.reWinkel,
					enable 				:= enableMotorControl,
					bumper 				:= bumper,
					MotorReset 			:= FALSE,
					actualVelMotor1 	:= -velWheel1, 
					actualVelMotor2 	:= -velWheel2, 
					actualVelMotor3 	:= -velWheel3,
					enableToMotor1 		=> enableToMotor1,
					enableToMotor2 		=> enableToMotor2,
					enableToMotor3 		=> enableToMotor3,
					velocityToMotor1	=> velocityToMotor1, 
					velocityToMotor2	=> velocityToMotor2,
					velocityToMotor3	=> velocityToMotor3);
				
				]]></ST>
    </Implementation>
    <Action Name="ACT_Drehzahlerfassung" Id="{fc784fde-e171-45e7-8902-8fc7a47aa187}">
      <Implementation>
        <ST><![CDATA[//Einlesen der Istwerte
//Motorstrom von der Klemme auslesen und umrechnen
Motor1current := UINT_TO_INT(currentfromMotor1);	//Umwandlung des Unsinged Integers in ein Integerwert
Motor2current := UINT_TO_INT(currentfromMotor2);
Motor3current := UINT_TO_INT(currentfromMotor3);

//Berechnung der Radgeschwindigkeit mit berücksichtigung des Getriebes
velWheel1 := -(UINT_TO_INT(n1fromMotor) / maxKlemmeDrehzahlMessung*maxMotorRPM/60*ue*2*PI*rWheel);
velWheel2 := -(UINT_TO_INT(n2fromMotor) / maxKlemmeDrehzahlMessung*maxMotorRPM/60*ue*2*PI*rWheel);
velWheel3 := -(UINT_TO_INT(n3fromMotor) / maxKlemmeDrehzahlMessung*maxMotorRPM/60*ue*2*PI*rWheel);]]></ST>
      </Implementation>
    </Action>
    <Method Name="ATAN2" Id="{d40dc8e0-f813-42c9-8c0e-8cd42b5707ec}">
      <Declaration><![CDATA[METHOD ATAN2 : LREAL
VAR_INPUT
    y : LREAL;
    x : LREAL;
END_VAR

VAR
    raw_angle : LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF x = 0.0 THEN
    IF y > 0.0 THEN
        ATAN2 := 90.0;
    ELSIF y < 0.0 THEN
        ATAN2 := 270.0;
    ELSE
        ATAN2 := 0.0;
    END_IF;

ELSE
    raw_angle := ATAN(y / x) * (180.0 / PI);

    IF x > 0.0 THEN
        ATAN2 := raw_angle;
    ELSE
        ATAN2 := raw_angle + 180.0;
    END_IF;

    IF ATAN2 < 0.0 THEN
        ATAN2 := ATAN2 + 360.0;
    END_IF;
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Beobachter" Id="{9009e981-b450-4d66-aef6-eef3267f676a}">
      <Declaration><![CDATA[METHOD Beobachter
VAR_INPUT
	wheelSpeed : WheelVelocity;
	cameraData : CameraConnectionUDP;
	RobotIndex : INT;
END_VAR
VAR_OUTPUT
	eastPos : sPosition := (reX := 0, reY := 0, reWinkel := 0);
END_VAR
VAR CONSTANT
	// === BEOBACHTER-PARAMETER => Großer Gain bedeutet hohes vertrauen in Kamera ===
	L_Gain					: REAL := 1.0;			// Luenberger Gain für X 		(0.0001-0.1)

	CYCLETIME 				: LREAL := 0.00033333;  // Cycletime des Motortasks
	CAMERA_DELAY			: REAL 	:= 0.1;
	BUFFWE_LENGTH			: INT 	:= 500;
	CAMERA_ERROR_THRESHOLD	: REAL 	:= 5.0;		// Fehlergrenze
	CAMERA_TIMEOUT			: LREAL := 30.0;		// Timeout in Sekunden
END_VAR

VAR_STAT
	bufferWheelSpeed	: ARRAY[0..BUFFWE_LENGTH] OF WheelVelocity;			// Speichern der letzten 300 Motorwerte (entspricht 100 ms -> Delay)
	prefCamPos			: sPosition;			// vorherige Kamera Position
	camPos				: sPosition;
	modelPos			: sPosition;
	CurrentTime			: LREAL;
	CameraTimestamp		: LREAL;
	actualError			: LREAL;				// Kamerafehler
	bufferIdx			: INT := 0;
	init				: BOOL;
END_VAR
VAR
	P_currentState 		: ARRAY[1..9] OF LREAL;	// Wär später für Kalmann	
	i					: INT;					// Iterrationsvariable
	averageWheelSpeed 	: WheelVelocity;
	x_estimated			: INT;
	angleError			: LREAL;
	idx					: INT;
	steps				: INT;
	startIdx			: INT;
	variableGain		: LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Am anfang einmal die Kammeraposition direkt übertragen
IF init = TRUE THEN
	// Wenn ein guter Kamerawert gefunden wurde direkt einmal übertragen
	IF cameraData.robotPosition[RobotIndex].e < CAMERA_ERROR_THRESHOLD THEN
		camPos.reX 			:= cameraData.robotPosition[RobotIndex].x;
		camPos.reY 			:= cameraData.robotPosition[RobotIndex].y;
		camPos.reWinkel 	:= cameraData.robotPosition[RobotIndex].theta;
		actualError			:= cameraData.robotPosition[RobotIndex].e;
		prefCamPos 	:= camPos;
		modelPos	:= camPos;
		eastPos		:= camPos;
		
		init := FALSE;
	END_IF
ELSE
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Radwerte in FIFO abspeichern
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	bufferWheelSpeed[bufferIdx] := wheelSpeed;
	bufferIdx := (bufferIdx + 1) MOD BUFFWE_LENGTH;
	
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Modell Propagieren
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	propagate_state(
				X_Start 	:= modelPos,
				wheelSpeed 	:= wheelSpeed, 
				P_Start 	:= P_currentState,
				deltaT 		:= CYCLETIME,
				X_Predict 	=> modelPos,
				P_Predict 	=> P_currentState
			);
	CurrentTime := CurrentTime + CYCLETIME;	// Zeit weiter laufen lassen, wenn keine Kameradaten kommen
	
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Kameradaten verarbeiten
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	
	// Kammeraposition erst validieren
	IF cameraData.robotPosition[RobotIndex].e > CAMERA_ERROR_THRESHOLD OR
		// Prüfen ob neue Kameraposition
	   ((prefCamPos.reX 	 = cameraData.robotPosition[RobotIndex].x)	AND
		(prefCamPos.reY 	 = cameraData.robotPosition[RobotIndex].y) 	AND
		(prefCamPos.reWinkel = cameraData.robotPosition[RobotIndex].theta)) THEN
			
			// Falls keine neue Kameraposition erscheint, auch die Kamera vorwärtspropagieren
			propagate_state(
					X_Start 	:= camPos,
					wheelSpeed 	:= wheelSpeed, 
					P_Start 	:= P_currentState,
					deltaT 		:= CYCLETIME,
					X_Predict 	=> camPos,
					P_Predict 	=> P_currentState
				);
	ELSE
		// Falls Kameraposition gut nehmen
		camPos.reX 			:= cameraData.robotPosition[RobotIndex].x;
		camPos.reY 			:= cameraData.robotPosition[RobotIndex].y;
		camPos.reWinkel 	:= cameraData.robotPosition[RobotIndex].theta;
		actualError			:= cameraData.robotPosition[RobotIndex].e;
		CameraTimestamp 	:= (cameraData.HH * 60 + cameraData.MM) * 60 + cameraData.SS;
		CurrentTime			:= CameraTimestamp;
		
		// Abspeichern der actualposition als alte Kameraposition

		prefCamPos := camPos;
		
		// Alle Werte zurückrechnen
		steps := LREAL_TO_INT(CAMERA_DELAY / CYCLETIME);
		startIdx := bufferIdx - steps;
		IF startIdx < 0 THEN
			startIdx := startIdx + BUFFWE_LENGTH;
		END_IF
			
		FOR i := 0 TO steps - 1 DO
			idx := startIdx + i;
			IF idx >= BUFFWE_LENGTH THEN
				idx := idx - BUFFWE_LENGTH;
			END_IF
		

			propagate_state(
				X_Start 	:= camPos,
				wheelSpeed 	:= bufferWheelSpeed[idx], 
				P_Start 	:= P_currentState,
				deltaT 		:= CYCLETIME,
				X_Predict 	=> camPos,
				P_Predict 	=> P_currentState
			);
		END_FOR	
	END_IF	
	
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	// LUENBERGER-KORREKTUR: x_hat = x_model + L * (y - x_model)
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
// 	variableGain := L_Gain * actualError/CAMERA_ERROR_THRESHOLD;
// 	IF variableGain > 1 OR variableGain < 0.0001 THEN
// 		variableGain := L_Gain;
// 	END_IF
// 	eastPos.reX 	 	:= modelPos.reX 		+ variableGain 	*	(camPos.reX 		- modelPos.reX);
// 	eastPos.reY 	 	:= modelPos.reY 		+ variableGain 	*	(camPos.reY 		- modelPos.reY);
// 	eastPos.reWinkel 	:= modelPos.reWinkel 	+ variableGain 	*	 NormalizeAngle(camPos.reWinkel - modelPos.reWinkel);

	eastPos.reX 	 	:= modelPos.reX 		+ L_Gain 	*	(camPos.reX 		- modelPos.reX);
	eastPos.reY 	 	:= modelPos.reY 		+ L_Gain 	*	(camPos.reY 		- modelPos.reY);
	eastPos.reWinkel 	:= modelPos.reWinkel 	+ L_Gain 	*	 NormalizeAngle(camPos.reWinkel - modelPos.reWinkel);
	modelPos := eastPos;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetMinDistance" Id="{94fd2004-0e4e-4d00-9d67-1d0424794927}">
      <Declaration><![CDATA[METHOD GetMinDistance : LREAL
VAR_INPUT
    velAngle    : LREAL;
    tolerance   : LREAL;
END_VAR
VAR
    i              : INT;
    sensorAngle    : LREAL;
    diff           : LREAL;
    minDistance    : LREAL := 1.0E+38;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
FOR i := 1 TO 9 DO
    sensorAngle := (i - 1) * 40.0;

    diff := sensorAngle - velAngle;

    IF diff > 180.0 THEN
        diff := diff - 360.0;
    ELSIF diff < -180.0 THEN
        diff := diff + 360.0;
    END_IF;

    IF ABS(diff) <= tolerance THEN
        minDistance := MIN(minDistance, IrDistanceSensors.distance_mm[i]);
    END_IF;
END_FOR;

GetMinDistance := minDistance;]]></ST>
      </Implementation>
    </Method>
    <Method Name="NormalizeAngle" Id="{83b90488-147b-4b1b-9c7b-cbb33d68b649}">
      <Declaration><![CDATA[METHOD NormalizeAngle
VAR_INPUT
	angle : LREAL;
END_VAR
VAR_OUTPUT
	NormalizeAngle :LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[WHILE angle > PI DO
    angle := angle - (2.0 * PI);
END_WHILE

WHILE angle < -PI DO
    angle := angle + (2.0 * PI);
END_WHILE

NormalizeAngle := angle;]]></ST>
      </Implementation>
    </Method>
    <Method Name="propagate_state" Id="{a786f7f3-c6cc-4af7-af4c-05fa1ad9f61a}">
      <Declaration><![CDATA[METHOD propagate_state
VAR_INPUT
	X_Start 	: sPosition;
    wheelSpeed 	: WheelVelocity;   (* w1,w2,w3 *)
	P_Start 	: ARRAY[1..9] OF LREAL;
	deltaT 		: LREAL;
END_VAR

VAR_OUTPUT
    X_Predict : sPosition;
	P_Predict : ARRAY[1..9] OF LREAL;
END_VAR

VAR
    (* Body velocities *)
    bodyVelX : LREAL;
    bodyVelY : LREAL;
    yawRate  : LREAL;

    (* Weltkoordinaten Geschw. *)
    worldVelX : LREAL;
    worldVelY : LREAL;

    (* Jacobian Elemente *)
    jac13 : LREAL;
    jac23 : LREAL;

    (* Diskrete Übergangsterme *)
    a13 : LREAL;
    a23 : LREAL;

    (* Prozessrauschen *)// Muss noch gemessen werden => Abweichen der Räder
    qx : LREAL := 0.001;
    qy : LREAL := 0.001;
    qyaw : LREAL := 0.001;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[(* ========================================================= *)
(*  EKF PREDICTION STEP – 3 Wheel Omni Robot                *)
(*  Zustandsvektor: x = [posX, posY, yaw]                   *)
(*  Modell: rein kinematisch                                 *)
(*  Diskretisierung: Vorwärts-Euler                          *)
(* ========================================================= *)

X_Start.reWinkel := -X_Start.reWinkel;

(* --- Wheel -> Body --- *)
bodyVelX := -(2.0/3.0) * (
			   -SIN(60  * PI/180) * wheelSpeed.wheel1
			   -SIN(180 * PI/180) * wheelSpeed.wheel2
			   -SIN(300 * PI/180) * wheelSpeed.wheel3
		   );

bodyVelY := -(2.0/3.0) * (
				COS(60  * PI/180) * wheelSpeed.wheel1
			  + COS(180 * PI/180) * wheelSpeed.wheel2
			  + COS(300 * PI/180) * wheelSpeed.wheel3
		   );

yawRate := -(wheelSpeed.wheel1 + wheelSpeed.wheel2 + wheelSpeed.wheel3) 
		   / (3.0 * GVL_RobotConstant.ROBOT_RADIUS * 1000);// Umrechnung in mm

(* --- Body -> World --- *)
worldVelX := bodyVelX * COS(X_Start.reWinkel)
		   - bodyVelY * SIN(X_Start.reWinkel);

worldVelY := bodyVelX * SIN(X_Start.reWinkel)
		   + bodyVelY * COS(X_Start.reWinkel);


(* --- Integration --- *)
X_Predict.reX 		:= X_Start.reX + deltaT * worldVelX;
X_Predict.reY 		:= X_Start.reY + deltaT * worldVelY;
X_Predict.reWinkel 	:= X_Start.reWinkel + deltaT * yawRate;


(* --- Winkel normalisieren --- *)

NormalizeAngle(angle := X_Predict.reWinkel, NormalizeAngle => X_Predict.reWinkel);

X_Predict.reWinkel := - X_Predict.reWinkel;


P_Predict := P_Start;
(*
(* ========================================================= *)
(* 4) Jacobi-Matrix F = ∂f/∂x                                *)
(*    Nur Ableitung nach yaw ist ≠ 0                         *)
(* ========================================================= *)

(* kontinuierliche Jacobi-Elemente *)

jac13 := -bodyVelX * SIN(X_Predict.reWinkel)
         -bodyVelY * COS(X_Predict.reWinkel);

jac23 :=  bodyVelX * COS(X_Predict.reWinkel)
         -bodyVelY * SIN(X_Predict.reWinkel);



(* ========================================================= *)
(* 5) Diskretisierung der Systemmatrix                       *)
(*    F_d = I + F*dt (Euler-Näherung)                        *)
(* ========================================================= *)

a13 := jac13 * deltaT;   (* entspricht F_d(1,3) *)
a23 := jac23 * deltaT;   (* entspricht F_d(2,3) *)



(* ========================================================= *)
(* 6) Kovarianz-Prediction                                   *)
(*    P = F_d * P * F_d^T + Q_d                              *)
(*                                                            *)
(*    P ist symmetrisch gespeichert:                          *)
(*    [ p11 p12 p13                                           *)
(*      p12 p22 p23                                           *)
(*      p13 p23 p33 ]                                         *)
(* ========================================================= *)

(* ---- Zwischenergebnis F_d * P * F_d^T ---- *)

P_Predict[1] := P_Start[1] + a13*(2.0*P_Start[3] + a13*P_Start[9]);
P_Predict[2] := P_Start[2] + a13*P_Start[6] + a23*P_Start[3] + a13*a23*P_Start[9];
P_Predict[3] := P_Start[3] + a13*P_Start[9];

P_Predict[5] := P_Start[5] + a23*(2.0*P_Start[6] + a23*P_Start[9]);
P_Predict[6] := P_Start[6] + a23*P_Start[9];

P_Predict[9] := P_Start[9];   (* yaw-Unsicherheit wächst nur durch Q *)



(* ========================================================= *)
(* 7) Prozessrauschen addieren                               *)
(*    Q_d = Q * dt                                           *)
(* ========================================================= *)

P_Predict[1] := P_Predict[1] + qx   * deltaT;
// P_Predict[2] := P_Predict[2];
// P_Predict[3] := P_Predict[3];

P_Predict[5] := P_Predict[5] + qy   * deltaT;
// P_Predict[6] := P_Predict[6];

P_Predict[9] := P_Predict[9] + qyaw * deltaT;
*)]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>